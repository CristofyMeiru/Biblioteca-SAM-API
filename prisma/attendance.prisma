enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model UserSchedule {
  id         String    @id @default(dbgenerated("gen_random_uuid()"))
  userId     String
  weekDay    WeekDay
  active     Boolean   @default(true)
  assignedAt DateTime  @default(now())
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id])

  @@map("user_schedule")
}

model AttendanceRecord {
  id     String   @id @default(dbgenerated("gen_random_uuid()"))
  date   DateTime
  active Boolean  @default(true)
  reason String?

  @@map("attendance_record")
}
